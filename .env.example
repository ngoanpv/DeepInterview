# DeepInterview — environment variables. Copy to .env (never commit .env).
# Run `pnpm deepinterview init` to scaffold this file.

# ── Core / app ─────────────────────────────────────────────
NODE_ENV=development
WEB_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Canonical public site URL (used for OG/canonical links). Standard Next.js var.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Agent API (web → agent proxy) ──────────────────────────
# The web app proxies report/coach reads to the agent service at this URL.
# docker-compose overrides this to http://agent-api:8000 (service DNS).
AGENT_API_URL=http://localhost:8000

# ── LiveKit (voice orchestration) ──────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Supabase (Postgres + Auth + Storage) ───────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Browser auth client reads the NEXT_PUBLIC_-prefixed names (inlined at build).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Cloudflare R2 (CV files + recordings) ──────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── STT (speech-to-text) ───────────────────────────────────
# Default = Deepgram nova-3 (the tested path); set DEEPGRAM_API_KEY.
# Soniox is a BYO alternative — set STT_PROVIDER=soniox + SONIOX_API_KEY.
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
SONIOX_API_KEY=

# ── TTS (text-to-speech) ───────────────────────────────────
TTS_PROVIDER=cartesia
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# ── LLM (live + prep/post) ─────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Web / company research ─────────────────────────────────
TAVILY_API_KEY=
EXA_API_KEY=

# ── Knowledge service (LightRAG sidecar) ───────────────────
LIGHTRAG_URL=http://localhost:9621
LIGHTRAG_PORT=9621

# ── Payments (hosted-only; OSS self-host runs without billing) ─
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
# Browser checkout reads the NEXT_PUBLIC_-prefixed Paddle vars (inlined at build).
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox
MOMO_PARTNER_CODE=
VNPAY_TMN_CODE=

# ── Observability (optional) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGSMITH_API_KEY=
SENTRY_DSN=
# Browser-side Sentry (inlined at build) + server trace sample rate (0.0–1.0).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=
