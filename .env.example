# DeepInterview — environment variables. Copy to .env (never commit .env).
# Run `pnpm deepinterview init` to scaffold this file.

# ── Core / app ─────────────────────────────────────────────
NODE_ENV=development
WEB_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── LiveKit (voice orchestration) ──────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Supabase (Postgres + Auth + Storage) ───────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Browser auth client reads the NEXT_PUBLIC_-prefixed names (inlined at build).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Cloudflare R2 (CV files + recordings) ──────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ── STT (speech-to-text) ───────────────────────────────────
STT_PROVIDER=soniox
SONIOX_API_KEY=
DEEPGRAM_API_KEY=

# ── TTS (text-to-speech) ───────────────────────────────────
TTS_PROVIDER=cartesia
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# ── LLM (live + prep/post) ─────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Web / company research ─────────────────────────────────
TAVILY_API_KEY=
EXA_API_KEY=

# ── Knowledge service (LightRAG sidecar) ───────────────────
LIGHTRAG_URL=http://localhost:9621
LIGHTRAG_PORT=9621

# ── Payments ───────────────────────────────────────────────
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
MOMO_PARTNER_CODE=
VNPAY_TMN_CODE=

# ── Observability (optional) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGSMITH_API_KEY=
SENTRY_DSN=
