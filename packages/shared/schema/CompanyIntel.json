{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "industry": {
      "default": null,
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "tech_stack": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "values": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interview_process": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recent_news": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "snippet": {
            "default": null,
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "title",
          "url"
        ]
      }
    }
  },
  "required": [
    "name",
    "summary",
    "tech_stack",
    "values",
    "interview_process",
    "recent_news",
    "citations"
  ]
}
