{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "gen:schema": {
      "outputs": ["schema/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["gen:schema"]
    },
    "@deepinterview/agent#test": {
      "dependsOn": ["@deepinterview/shared#gen:schema"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
